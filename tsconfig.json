{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@scenes/*": ["src/scenes/*"],
      "@systems/*": ["src/game/systems/*"],
      "@data/*": ["src/game/data/*"],
      "@views/*": ["src/scenes/views/*"],
      "@utils/*": ["src/game/utils/*"],
      "@assets/*": ["assets/*"]
    },
    "include": ["src/**/*.js", "src/**/*.ts", "src/**/*.d.ts", "assets/data/json/**/*.json"]
  },
  "exclude": ["node_modules", "dist"]
}
